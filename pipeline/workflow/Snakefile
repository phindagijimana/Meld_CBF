# ===========================================================================
# MELD + CBF — Snakemake workflow
#
#   prepare → meld → register (+ stats) → visualize → aggregate
#
# Run via the `meldcbf` CLI (recommended) or directly:
#   snakemake -s workflow/Snakefile --cores 1            # default target = rule all
#   snakemake -s workflow/Snakefile --profile profiles/slurm
# ===========================================================================
from pathlib import Path

# Default config (CLI passes --configfile to override). Resolved relative to
# this Snakefile so direct `snakemake` invocations also work.
configfile: str(Path(workflow.basedir).parent / "config" / "config.yaml")


include: "rules/common.smk"
include: "rules/prepare.smk"
include: "rules/meld.smk"
include: "rules/register.smk"
include: "rules/visualize.smk"
include: "rules/aggregate.smk"


rule all:
    default_target: True
    input:
        COHORT_CSV,
        expand(viz_flag("{sub}"), sub=SUBJECTS),
